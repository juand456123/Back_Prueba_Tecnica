              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"{{clientId}}\",\n  \"fundId\": \"{{fundId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/subscriptions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "subscriptions"
              ]
            }
          },
          "response": []
        }
