    {
      "name": "03 - Subscriptions",
      "item": [
        {
          "name": "Subscribe to Fund",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"{{clientId}}\",\n  \"fundId\": \"{{fundId}}\",\n  \"amount\": 500000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/subscriptions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "subscriptions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Cancel Subscription",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
